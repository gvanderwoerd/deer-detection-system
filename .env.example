# Deer Detection System - Environment Configuration
# Copy this file to .env and fill in your actual values

# Tuya Cloud API Configuration
TUYA_API_KEY=your-tuya-api-key-here
TUYA_API_SECRET=your-tuya-api-secret-here
TUYA_CLOUD_REGION=us

# Device Configuration
PRIMARY_VALVE_ID=your-device-id-here

# Flask Configuration
FLASK_SECRET_KEY=change-this-to-a-random-secret-key

# Optional: ESP32 Configuration
ESP32_CAM_URL=http://esp32cam.local:81/
