[Desktop Entry]
Version=1.0
Type=Application
Name=Sprinkler Start
Comment=Start Deer Detection System and open dashboard
Exec=/bin/bash -c "cd /mnt/linux-data/deer-detection-system && ./start.sh && sleep 3 && xdg-open http://192.168.1.15:5000"
Icon=applications-games
Terminal=false
Categories=Utility;Application;
StartupNotify=true
